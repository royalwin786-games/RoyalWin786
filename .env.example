# Public browser configuration. Copy this file to .env.local for development.
# Never put a Supabase service-role or secret key in a React environment variable.
REACT_APP_ENABLE_LIVE_BACKEND=false
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key
